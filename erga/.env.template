# Copy to .env and fill in values for this deployment. Never commit .env.

# Deployment
URL_PREFIX = /cbp-dev          # /cbp-dev for dev, /cbp for prod
STATIC_URL = /cbp-dev/static/  # omit to derive from URL_PREFIX; prod may need /static/
DB_NAME = cbp_dev              # cbp_dev for dev, cbp for prod
LOG_FILE = /path/to/app.log
EAR_STUCK_THRESHOLD_DAYS = 7  # days before an in-review EAR is flagged stuck
ENABLE_CRONS = False           # True in prod to enable background cron jobs

# allauth — set both to False/none in dev to allow no-email test accounts
# ACCOUNT_UNIQUE_EMAIL is intentionally omitted: leave it True (default) or allauth
# will refuse to start when ACCOUNT_AUTHENTICATION_METHOD includes email.
ACCOUNT_EMAIL_REQUIRED = True
ACCOUNT_EMAIL_VERIFICATION = mandatory

# Email backend — use dummy in dev, smtp in prod
EMAIL_BACKEND = django.core.mail.backends.smtp.EmailBackend

# Secrets
SECRET_KEY =
DB_PASSWORD =
EMAIL_HOST_USER =
EMAIL_HOST_PASSWORD =
DEFAULT_FROM_EMAIL =
GITHUB_TOKEN =
